<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Cyan Modern Calculator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        :root {
            --theme-main: #06b6d4; /* Cyan 500 */
            --theme-dark: #0891b2; /* Cyan 600 */
            --theme-light: #ecfeff; /* Cyan 50 */
            --bg-page: #e0f2fe; /* Sky/Cyan 100 base */
            --text-main: #164e63; /* Cyan 900 */
            --text-muted: #22d3ee; /* Cyan 400 */
            
            --glass-bg: rgba(255, 255, 255, 0.95);
            --glass-border: rgba(6, 182, 212, 0.15);
            
            --btn-bg: #ffffff;
            --btn-shadow: 0 4px 6px -1px rgba(6, 182, 212, 0.1);
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg-page);
            color: var(--text-main);
            min-height: 100dvh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1rem;
        }

        .calculator {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            padding: 2rem;
            width: 100%;
            max-width: 380px;
            box-shadow: 0 20px 25px -5px rgba(6, 182, 212, 0.15);
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            position: relative;
            overflow: hidden;
        }

        .display {
            background: #f0fdff;
            border-radius: 20px;
            padding: 1.5rem;
            text-align: right;
            border: 1px solid var(--glass-border);
            min-height: 120px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .previous-operand { color: var(--text-muted); font-size: 0.9rem; }
        .current-operand { color: var(--text-main); font-size: 2.5rem; font-weight: 700; }

        .keypad { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

        .btn {
            background: var(--btn-bg);
            border: 1px solid rgba(6, 182, 212, 0.1);
            border-radius: 16px;
            aspect-ratio: 1 / 1;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.25rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: var(--btn-shadow);
        }

        .btn[data-number] { background: var(--theme-light); color: var(--text-main); }

        .btn:hover { transform: translateY(-2px); filter: brightness(0.98); }
        .btn:active { transform: translateY(0); }

        .btn-operator { color: var(--theme-main); }
        .btn-action { color: #22d3ee; opacity: 0.9; }
        
        .btn-equals { background: var(--theme-main); color: white; grid-column: span 2; aspect-ratio: auto; border-radius: 20px; }
        .btn-equals:hover { background: var(--theme-dark); }

        .history-panel {
            position: absolute; bottom: 0; left: 0; width: 100%; height: 90%;
            background: white; border-radius: 32px 32px 0 0; z-index: 30;
            padding: 1.5rem; transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex; flex-direction: column; gap: 1rem;
        }
        .history-panel.open { transform: translateY(0); }
        .history-list { flex-grow: 1; overflow-y: auto; }
        .history-item { padding: 0.75rem; border-bottom: 1px solid #ecfeff; cursor: pointer; }
    </style>
</head>
<body>

    <div class="calculator">
        <div class="flex items-center justify-between">
            <span class="text-xs font-bold uppercase tracking-widest text-cyan-400">Calculator</span>
            <button id="history-toggle-btn" class="p-2 rounded-full hover:bg-cyan-50 text-cyan-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </button>
        </div>

        <div class="display">
            <div class="previous-operand" id="previous-operand"></div>
            <div class="current-operand" id="current-operand">0</div>
        </div>

        <div class="keypad">
            <button class="btn btn-action" data-action="clear">AC</button>
            <button class="btn btn-action" data-action="delete">DEL</button>
            <button class="btn btn-action" data-action="percent">%</button>
            <button class="btn btn-operator" data-operation="÷">÷</button>
            
            <button class="btn" data-number="7">7</button>
            <button class="btn" data-number="8">8</button>
            <button class="btn" data-number="9">9</button>
            <button class="btn btn-operator" data-operation="×">×</button>
            
            <button class="btn" data-number="4">4</button>
            <button class="btn" data-number="5">5</button>
            <button class="btn" data-number="6">6</button>
            <button class="btn btn-operator" data-operation="-">−</button>
            
            <button class="btn" data-number="1">1</button>
            <button class="btn" data-number="2">2</button>
            <button class="btn" data-number="3">3</button>
            <button class="btn btn-operator" data-operation="+">+</button>
            
            <button class="btn" data-number="0">0</button>
            <button class="btn" data-number=".">.</button>
            <button class="btn btn-equals" data-action="calculate">=</button>
        </div>

        <div class="history-panel" id="history-panel">
            <div class="flex justify-between items-center">
                <h3 class="font-bold text-cyan-900">History</h3>
                <button id="history-close-btn" class="text-cyan-400 hover:text-cyan-600">✕</button>
            </div>
            <div class="history-list" id="history-list"></div>
            <button id="history-clear-btn" class="w-full py-2 bg-cyan-50 text-cyan-600 rounded-xl font-semibold hover:bg-cyan-100">Clear</button>
        </div>
    </div>

    <script>
        class Calculator {
            constructor(p, c) { this.prevEl = p; this.currEl = c; this.history = JSON.parse(localStorage.getItem('calc_history')) || []; this.clear(); this.updateHistoryUI(); }
            clear() { this.curr = '0'; this.prev = ''; this.op = undefined; }
            delete() { this.curr = this.curr.slice(0, -1) || '0'; }
            appendNumber(n) { if (n === '.' && this.curr.includes('.')) return; this.curr = this.curr === '0' && n !== '.' ? n : this.curr + n; }
            chooseOperation(op) { if (this.curr === '') return; if (this.prev !== '') this.compute(); this.op = op; this.prev = this.curr; this.curr = ''; }
            compute() {
                let p = parseFloat(this.prev), c = parseFloat(this.curr);
                if (isNaN(p) || isNaN(c)) return;
                let res;
                switch (this.op) {
                    case '+': res = p + c; break;
                    case '−': res = p - c; break;
                    case '×': res = p * c; break;
                    case '÷': res = c === 0 ? 'Error' : p / c; break;
                }
                this.saveToHistory(`${this.prev} ${this.op} ${this.curr}`, res);
                this.curr = res.toString(); this.op = undefined; this.prev = '';
            }
            saveToHistory(ex, res) { this.history.unshift({ex, res}); localStorage.setItem('calc_history', JSON.stringify(this.history)); this.updateHistoryUI(); }
            updateHistoryUI() { document.getElementById('history-list').innerHTML = this.history.map(i => `<div class="history-item text-cyan-900">${i.ex} = ${i.res}</div>`).join(''); }
            update() { this.currEl.innerText = this.curr; this.prevEl.innerText = this.op ? `${this.prev} ${this.op}` : ''; }
        }
        const calc = new Calculator(document.getElementById('previous-operand'), document.getElementById('current-operand'));
        document.querySelectorAll('[data-number]').forEach(b => b.addEventListener('click', () => { calc.appendNumber(b.innerText); calc.update(); }));
        document.querySelectorAll('[data-operation]').forEach(b => b.addEventListener('click', () => { calc.chooseOperation(b.innerText); calc.update(); }));
        document.querySelector('[data-action="calculate"]').addEventListener('click', () => { calc.compute(); calc.update(); });
        document.querySelector('[data-action="clear"]').addEventListener('click', () => { calc.clear(); calc.update(); });
        document.querySelector('[data-action="delete"]').addEventListener('click', () => { calc.delete(); calc.update(); });
        document.getElementById('history-toggle-btn').addEventListener('click', () => document.getElementById('history-panel').classList.add('open'));
        document.getElementById('history-close-btn').addEventListener('click', () => document.getElementById('history-panel').classList.remove('open'));
        document.getElementById('history-clear-btn').addEventListener('click', () => { calc.history = []; localStorage.removeItem('calc_history'); calc.updateHistoryUI(); });
    </script>
</body>
</html>
